datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Contact {
  id                        String   @id @default(uuid())
  fullName                  String
  department                String
  graduationYear            Int
  currentProfessionOrPosition String
  linkedinUrl               String
  photoUrl                  String
  email                     String
  mobileNumber              String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}
